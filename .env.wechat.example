# 微信支付配置（获取商户号后填写）
# 重要：不要将此文件提交到Git，应添加到.gitignore

# 微信支付商户号
WECHAT_PAY_MCHID=

# 微信支付API v3密钥（32位）
WECHAT_PAY_API_V3_KEY=

# 微信支付商户API证书序列号
WECHAT_PAY_SERIAL_NO=

# 微信公众号APPID（如果是公众号支付）或小程序APPID
WECHAT_PAY_APPID=

# 微信支付通知回调地址（需要公网可访问的HTTPS地址）
WECHAT_PAY_NOTIFY_URL=https://yourdomain.com/api/payment/wechat/notify

# API证书路径
WECHAT_PAY_CERT_PATH=./certs/apiclient_cert.pem
WECHAT_PAY_KEY_PATH=./certs/apiclient_key.pem
